# openai 格式密钥
OPENAI_API_KEY=your_openai_api_key_here

# 代理地址
OPENAI_API_BASE=https://api.siliconflow.cn/v1

# LangSmith 密钥
#LANGSMITH_API_KEY=your_langsmith_api_key_here

# 启用 LangSmith 追踪（true/false）
#LANGSMITH_TRACING=false

# LangSmith 项目名称
#LANGSMITH_PROJECT=langchain-v1-study

# LangSmith 端点（通常不需要修改）
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Tavily Search API（推荐用于 AI 搜索）
# 获取地址: https://tavily.com/
# TAVILY_API_KEY=your_tavily_api_key_here

# Serper API（Google 搜索）
# 获取地址: https://serper.dev/
# SERPER_API_KEY=your_serper_api_key_here

# SerpAPI（Google 搜索）
# 获取地址: https://serpapi.com/
# SERPAPI_API_KEY=your_serpapi_api_key_here

# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# 开发模式（true/false）
DEV_MODE=true

# 最大重试次数
MAX_RETRIES=3

# 请求超时时间（秒）
REQUEST_TIMEOUT=30

# 默认使用的模型
DEFAULT_MODEL=Pro/MiniMaxAI/MiniMax-M2.5

# 默认温度参数（0.0 - 2.0）
DEFAULT_TEMPERATURE=0.7

# 默认最大 Token 数
DEFAULT_MAX_TOKENS=2000
